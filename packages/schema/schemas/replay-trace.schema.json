{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-record-replay.local/schemas/replay-trace.schema.json",
  "type": "object",
  "required": ["schema_version", "kind", "id", "workflow_id", "status", "steps"],
  "properties": {
    "schema_version": { "const": 1 },
    "kind": { "const": "replay_trace" },
    "id": { "type": "string" },
    "workflow_id": { "type": "string" },
    "started_at": { "type": "string" },
    "ended_at": { "type": "string" },
    "status": { "enum": ["passed", "failed", "dry_run"] },
    "steps": { "type": "array" }
  }
}
