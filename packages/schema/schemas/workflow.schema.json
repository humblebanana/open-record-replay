{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-record-replay.local/schemas/workflow.schema.json",
  "type": "object",
  "required": ["schema_version", "kind", "id", "name", "steps"],
  "properties": {
    "schema_version": { "const": 1 },
    "kind": { "const": "workflow" },
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "compiled_from_session_id": { "type": ["string", "null"] },
    "parameters": { "type": "array" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "name", "action", "assertions"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "source_event_ids": { "type": "array" },
        "context": { "type": "object" },
        "target": { "type": "object" },
        "action": { "type": "object", "required": ["kind"] },
        "assertions": { "type": "array", "minItems": 1 },
        "timeout_ms": { "type": "number" },
        "risk_level": { "enum": ["low", "medium", "high"] }
      }
    }
  }
}
